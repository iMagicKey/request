{
    "name": "imagic-request",
    "version": "1.0.4",
    "description": "Send HTTP requests with support for JSON, binary, multipart, and compressed responses",
    "type": "module",
    "exports": {
        ".": "./src/index.js",
        "./package.json": "./package.json"
    },
    "files": [
        "src",
        "README.md",
        "LICENSE"
    ],
    "sideEffects": false,
    "scripts": {
        "test": "node --test ./tests/**/*.test.js",
        "lint": "eslint src tests",
        "lint:fix": "eslint src tests --fix",
        "prettier": "npx prettier --write ."
    },
    "engines": {
        "node": ">=24"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/iMagicKey/request.git"
    },
    "keywords": [
        "imagic",
        "request",
        "node",
        "http"
    ],
    "author": "iMagicKey",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/iMagicKey/request/issues"
    },
    "homepage": "https://github.com/iMagicKey/request#readme",
    "devDependencies": {
        "@eslint/js": "^9.24.0",
        "chai": "latest",
        "eslint": "^9.24.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-promise": "^7.2.1",
        "globals": "^16.0.0",
        "prettier": "^3.8.1"
    }
}
